{
  "name": "zmyun-cli",
  "version": "0.1.7",
  "description": "Agent-friendly CLI for ZMY collection and project workflows.",
  "type": "module",
  "homepage": "https://github.com/superjack2050/zmyun-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superjack2050/zmyun-cli.git"
  },
  "bugs": {
    "url": "https://github.com/superjack2050/zmyun-cli/issues"
  },
  "bin": {
