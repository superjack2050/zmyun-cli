  },
  "files": [
    "dist/auth.js",
    "dist/batch.js",
    "dist/cli.js",
    "dist/collection-actions.js",
    "dist/collection-create.js",
    "dist/collection-variants.js",
    "dist/collections.js",
    "dist/config.js",
    "dist/constants.js",
    "dist/credentials.js",
    "dist/errors.js",
    "dist/http.js",
